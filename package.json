{
  "name": "openmind",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "lint:fix:files": "eslint --fix",
    "functions:serve:local": "supabase functions serve --env-file .env",
    "db:reset:local": "supabase db reset --local",
    "db:reset:remote": "supabase db reset --linked",
    "db:generate-types:local": "supabase gen types typescript --local > shared/types/database.ts",
    "db:generate-types:remote": "supabase gen types typescript --linked > shared/types/database.ts",
    "migrate:data": "tsx scripts/data-migration/index.ts"
  },
  "dependencies": {
    "@editorjs/editorjs": "^2.31.3",
    "@editorjs/header": "^2.8.8",
    "@editorjs/list": "^2.0.9",
    "@editorjs/paragraph": "^2.11.7",
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/hints": "^1.0.0-alpha.6",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/seo": "^3.4.0",
    "@nuxtjs/supabase": "^2.0.4",
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-query-devtools": "^6.1.5",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "editorjs-html": "^4.0.5",
    "isomorphic-dompurify": "^2.36.0",
    "lucide-vue-next": "^0.574.0",
    "nuxt": "^4.3.1",
    "reka-ui": "^2.8.2",
    "shadcn-nuxt": "^2.4.3",
    "tailwind-merge": "^3.4.1",
    "ufo": "^1.6.3",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-prettier": "^5.5.5",
    "node-html-parser": "^7.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4"
  }
}
